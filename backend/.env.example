# ============================================================
# APIScan Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit the actual .env file to version control!
# ============================================================

# -------------------------
# Spring Profile
# -------------------------
SPRING_PROFILES_ACTIVE=dev

# -------------------------
# Database (PostgreSQL)
# -------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/apiscan_db
SPRING_DATASOURCE_USERNAME=apiscan
SPRING_DATASOURCE_PASSWORD=apiscan123

# -------------------------
# Redis
# -------------------------
REDIS_URL=redis://localhost:6379

# -------------------------
# RabbitMQ
# -------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=apiscan
RABBITMQ_PASSWORD=apiscan123

# -------------------------
# JWT Secrets (min 64 chars)
# -------------------------
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-minimum-string-for-access-token-signing-key
JWT_REFRESH_SECRET=change-me-to-a-random-64-char-minimum-string-for-refresh-token-signing-key
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# -------------------------
# Stripe Billing
# -------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# -------------------------
# Email (SMTP / AWS SES)
# -------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

# -------------------------
# AWS S3 (Report Exports)
# -------------------------
AWS_S3_BUCKET=apiscan-reports
AWS_REGION=ap-south-1

# -------------------------
# Sentry Error Tracking
# -------------------------
SENTRY_DSN=

# -------------------------
# Frontend URL (CORS)
# -------------------------
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -------------------------
# Server
# -------------------------
SERVER_PORT=8080
